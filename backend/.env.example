# ---- Dataverse AI Interview Coach: backend env ----
# Copy to .env for local dev. On Railway, set these as service variables.
# "Free now -> paid later" is a one-line change here (PRD §8).

# --- LLM (chat) ---
# Pick a provider; the matching key below is found automatically. Groq is the recommended
# free default (reliable, fast). OpenRouter free models work but are heavily rate-limited (429).
LLM_PROVIDER=groq
# LLM_MODEL=                   # optional; defaults to a sensible free model per provider
# LLM_BASE_URL=               # optional override (self-host / proxy)
LLM_TEMPERATURE=0.6

# Provider-specific keys (set the one(s) you use). LLM_API_KEY overrides all if set.
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
# LLM_API_KEY=

# Paid later, e.g.:  LLM_PROVIDER=anthropic LLM_MODEL=claude-sonnet-4-6
#            (or)    LLM_PROVIDER=openai    LLM_MODEL=gpt-4o-mini

# --- Embeddings (RAG) ---
# tfidf = zero-dependency default (works today). fastembed = free local semantic search.
EMBED_PROVIDER=tfidf
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Supabase (Postgres + Auth) ---
# Use the POOLER connection string (Supabase Connect -> Transaction/Session pooler).
# New projects don't expose db.<ref>.supabase.co; the pooler host includes your region.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<ref>.supabase.co          # or NEXT_PUBLIC_SUPABASE_URL
SUPABASE_ANON_KEY=                               # or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_KEY=                            # or APIKEY (sb_secret_...)
# SUPABASE_JWT_SECRET=                           # optional; auth verifies via Supabase API
APP_ENV=development
# PORT is provided by Railway automatically.
